# ───────────────────────────── Python / FastAPI ─────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / type-checker / linter caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/
.tox/

# Packaging / build artifacts
build/
*.egg-info/
.eggs/

# SQLite database files (e.g. gift.db)
*.db
*.sqlite
*.sqlite3

# ───────────────────────────── Node / React / Vite ──────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Vite / build caches
.vite/

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────── Environment files ────────────────────────────
# Ignore real secrets, but keep the committed template.
.env
.env.*
!.env.example

# ───────────────────────────── Editor / IDE ─────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ───────────────────────────── OS junk ──────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini